// C++ per-language fixture covering the 6 first-batch
// stdlib bridging types. Pairs with minimal.cpp (matching signatures).
//
// Mapping verified by CppEmitter:
//   bool          -> bool
//   i64           -> std::int64_t
//   f64           -> double
//   string        -> std::string_view   (UTF-8, non-owning)
//   optional<T>   -> std::optional<T>
//   slice<T>      -> topo::span<const T>

namespace stdlib_smoke {
  public:
    bool isReady();
    i64 nextId();
    f64 score(i64 id);
    string label(i64 id);
    optional<i64> parentOf(i64 id);
    slice<f64> samples();

    // All-types-in-one signature — mirrors the stdlib acceptance check.
    optional<i64> boundary(i64 id,
                           string name,
                           optional<bool> flag,
                           slice<f64> values);
}
