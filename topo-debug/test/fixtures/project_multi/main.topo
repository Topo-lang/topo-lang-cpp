// Project-level multi-variable summary fixture.
//
// Two host arrays in scope (`int a[4]`, `int b[4]`) — the summary
// template references both, so resolving it requires the multi-var
// adapter protocol. The summary batching refactor packs all
// placeholder vars into a single adapter spawn.

std::import("cstdint", int32_t);

namespace app {
  public:
    type TwoArrays {
      public:
        int32_t a;
        int32_t b;
    }
}

debug TwoArrays {
  view first from a[0..2];
  view second from b[2..4];
  // Placeholders resolve to host variables `a` and `b` directly (binary
  // arith on the values is evaluated by the query engine, not the
  // adapter). At main.cpp:15:
  //   sum(a)              = 10
  //   sum(b)              = 100
  //   sum(a) + sum(b)     = 110
  //   max(b) - max(a)     = 36
  summary "a={sum(a)}, b={sum(b)}, total={sum(a) + sum(b)}, span={max(b) - max(a)}";
}
